      {
        "type": "names_list",

        "explanations": [
          {
            "type": "simple",
            "text": "Arrays can store multiple names."
          },

          {
            "type": "student_friendly",
            "text": "One array can store many people names."
          },

          {
            "type": "real_life",
            "text": "Contact apps store names in arrays."
          },

          {
            "type": "technical",
            "text": "String[] arrays store text values."
          },

          {
            "type": "deep",
            "text": "Arrays help organize textual datasets efficiently."
          }
        ],

        "code": "String[] names = {\"John\", \"Alex\", \"Sam\"};",

        "output": "John Alex Sam",

        "step_by_step": [
