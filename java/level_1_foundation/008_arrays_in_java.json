      },

      {
        "type": "shopping_prices",

        "explanations": [
          {
            "type": "simple",
            "text": "Arrays can store multiple prices."
          },

          {
            "type": "student_friendly",
            "text": "Shopping apps use arrays for product prices."
          },

          {
            "type": "real_life",
            "text": "E-commerce apps store prices in arrays."
          },

          {
            "type": "technical",
            "text": "double[] arrays store decimal values efficiently."
          },

          {
            "type": "deep",
            "text": "Arrays help process pricing and billing systems."
          }
        ],

        "code": "double[] prices = {99.99, 150.50, 75.25};",

        "output": "99.99 150.50 75.25",

        "step_by_step": [
