            "text": "Arrays can store multiple game scores."
          },

          {
            "type": "student_friendly",
            "text": "One array tracks scores of many players."
          },

          {
            "type": "real_life",
            "text": "Games use arrays for leaderboards."
          },

          {
            "type": "technical",
            "text": "Arrays organize sequential player score data."
          },

          {
            "type": "deep",
            "text": "Gaming systems rely on arrays for ranking and score management."
          }
        ],

        "code": "int[] scores = {100, 200, 150, 300};",

        "output": "100 200 150 300",

        "step_by_step": [
