          {
            "type": "real_life",
            "text": "Schools use arrays to manage marks."
          },

          {
            "type": "technical",
            "text": "Integer arrays efficiently store numeric marks."
          },

          {
            "type": "deep",
            "text": "Arrays simplify managing academic records in education systems."
          }
        ],

        "code": "int[] marks = {90, 85, 95};",

        "output": "90 85 95",

        "step_by_step": [
          "marks array stores 3 values",
          "Each value gets index",
          "marks[0] = 90",
          "marks[1] = 85",
          "marks[2] = 95"
        ],

        "real_life": "School marks system."
      },

      {
