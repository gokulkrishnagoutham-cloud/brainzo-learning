          "attendance tracks student status",
          "Each student gets separate index",
          "true means present",
          "false means absent"
        ],

        "real_life": "School attendance systems."
      }
    ],

    "accessing_elements": {

      "title": "Accessing Array Elements",

      "explanations": [
        {
          "type": "simple",
          "text": "Indexes access array values."
        },

        {
          "type": "student_friendly",
          "text": "Each array value has position number."
        },

        {
          "type": "real_life",
          "text": "Indexes work like locker numbers."
        },

        {
          "type": "technical",
          "text": "Array indexes start from 0."
        },

        {
          "type": "deep",
          "text": "Indexed access provides fast retrieval operations."
        }
      ],

      "example": {
        "code": "int[] marks = {90, 85, 95};\n\nSystem.out.println(marks[0]);",

        "output": "90"
      },

      "step_by_step": [
        "marks[0] accesses first element",
        "Index starts from 0",
        "First value becomes 90",
        "System.out.println() prints value",
        "90 appears on screen"
      ]
    },

    "changing_values": {

      "title": "Updating Array Values",

      "explanations": [
        {
          "type": "simple",
          "text": "Array values can be changed."
        },

        {
          "type": "student_friendly",
          "text": "Indexes help replace old values."
        },

        {
          "type": "real_life",
          "text": "Marks can be updated after revaluation."
        },

        {
          "type": "technical",
          "text": "Array elements are mutable."
        },

        {
          "type": "deep",
          "text": "Indexed updates allow efficient modification operations."
        }
      ],

      "example": {
        "code": "marks[1] = 100;",

        "output": "Second element becomes 100"
      },

      "step_by_step": [
        "marks[1] accesses second element",
        "Old value becomes 85",
        "100 replaces old value",
        "Array updates successfully",
        "New value becomes stored"
      ]
    },

    "array_length": {

      "title": "Finding Array Length",

      "explanations": [
        {
          "type": "simple",
          "text": "length gives total array size."
        },

        {
          "type": "student_friendly",
          "text": "length tells how many values exist."
        },

        {
          "type": "real_life",
          "text": "Apps use length to count items."
        },

        {
          "type": "technical",
          "text": "length is built-in array property."
        },

        {
          "type": "deep",
          "text": "length supports dynamic traversal and validation operations."
        }
      ],

      "example": {
        "code": "System.out.println(marks.length);",

        "output": "3"
      }
    },

    "loops_with_arrays": {

      "title": "Using Loop with Arrays",

      "explanations": [
        {
          "type": "simple",
          "text": "Loops help print all array values."
        },

        {
          "type": "student_friendly",
          "text": "Loops remove need for repeated code."
        },

        {
          "type": "real_life",
          "text": "Apps process lists using loops."
        },

        {
          "type": "technical",
          "text": "Loops traverse arrays sequentially."
        },

        {
          "type": "deep",
          "text": "Array traversal is fundamental for algorithms and data processing."
        }
      ],

      "example": {
        "code": "int[] marks = {90, 85, 95};\n\nfor(int i = 0; i < marks.length; i++) {\n    System.out.println(marks[i]);\n}",

        "output": [
          "90",
          "85",
          "95"
        ]
      },

      "step_by_step": [
        "Loop starts from index 0",
        "Loop continues until last index",
        "marks[i] accesses each value",
        "Values print one by one",
        "All elements become displayed"
      ]
    },

    "wrong_vs_correct": [
      {
        "wrong": "int[] marks = 90, 85, 95;",
        "correct": "int[] marks = {90, 85, 95};",
        "why_wrong": "Arrays require curly braces."
      },

      {
        "wrong": "marks[3]",
        "correct": "marks[2]",
        "why_wrong": "Indexes start from 0. Last index is size - 1."
      },

      {
        "wrong": "marks.length()",
        "correct": "marks.length",
        "why_wrong": "length in arrays is property, not method."
      },

      {
        "wrong": "String[] names = {John, Alex};",
        "correct": "String[] names = {\"John\", \"Alex\"};",
        "why_wrong": "String values require double quotes."
      },

      {
        "wrong": "int[] arr = new int[-1];",
        "correct": "int[] arr = new int[5];",
        "why_wrong": "Array size cannot be negative."
      }
    ],

    "common_mistakes": [
      "Forgetting indexes start at 0",
      "Accessing invalid index",
      "Using wrong array syntax",
      "Confusing length and length()",
      "Storing different datatypes together"
    ],

