            "output": "isDarkMode stores false",

            "step_by_step": [
              "stores theme setting"
            ],

            "real_life": "Used in app settings."
          }
        ]
      }
    ],

    "wrong_vs_correct": [
      {
        "wrong": "int age = \"20\";",
        "correct": "int age = 20;",
        "why_wrong": "int cannot store text values."
      },

      {
        "wrong": "String name = 'John';",
        "correct": "String name = \"John\";",
        "why_wrong": "String uses double quotes."
      },

      {
        "wrong": "char grade = \"A\";",
        "correct": "char grade = 'A';",
        "why_wrong": "char stores only one character using single quotes."
      },

      {
        "wrong": "boolean isStudent = \"true\";",
        "correct": "boolean isStudent = true;",
        "why_wrong": "boolean stores true or false without quotes."
      }
    ],

    "common_mistakes": [
      "Forgetting semicolon ;",
      "Using wrong datatype",
      "Using single quotes for String",
      "Using double quotes for char",
      "Giving spaces in variable names"
    ],

    "practice": [
      "Create 5 int variables.",
      "Create 5 String variables.",
      "Create 5 double variables.",
      "Create 5 char variables.",
      "Create 5 boolean variables.",
      "Print all variables using System.out.println()."
    ],

    "quiz": [
      {
