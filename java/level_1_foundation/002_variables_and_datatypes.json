{
  "id": "java_foundation_variables",
  "title": "Variables in Java",
  "difficulty": "Beginner",
  "estimatedMinutes": 20,

  "content": {
    "topic_intro": "Variables are used to store data in Java programs.",

    "explanations": [
      {
        "type": "simple",
        "title": "Simple Explanation",
        "text": "A variable is a container used to store information."
      },

      {
        "type": "real_life",
        "title": "Real Life Explanation",
        "text": "A variable is like a labeled bottle. The label tells what is inside, and the bottle stores the value."
      },

      {
        "type": "student_friendly",
        "title": "Student Friendly Explanation",
        "text": "Variables help programs remember things like names, marks, scores, and prices."
      },

      {
        "type": "technical",
        "title": "Technical Explanation",
        "text": "A variable reserves memory space in RAM to store a specific datatype value."
      },

      {
        "type": "deep",
        "title": "Deep Explanation",
        "text": "Variables combine datatype, variable name, and assigned value to manage application state and data flow during program execution."
      }
    ],

    "syntax": {
      "code": "datatype variableName = value;",
      "explanation": "A variable contains datatype, variable name, assignment operator, and value."
    },

