{
  "id": "java_foundation_002",
  "title": "Variables and Datatypes",
  "difficulty": "Beginner",
  "estimatedMinutes": 35,

  "content": {
    "topic_intro": "Variables are used to store data in Java programs.",

    "why_learn_this": "Without variables, programs cannot remember names, scores, prices, ages, login states, or any information.",

    "explanations": [
      {
        "type": "simple",
        "text": "A variable is a container used to store data."
      },

      {
        "type": "real_life",
        "text": "A variable is like a labeled bottle. The label tells what is inside, and the bottle stores the value."
      },

      {
        "type": "student_friendly",
        "text": "Variables help programs remember information like marks, names, and scores."
      },

      {
        "type": "technical",
        "text": "Variables reserve memory space to store values of specific datatypes."
      },

      {
        "type": "deep",
        "text": "Variables combine datatype, variable name, and assigned value to manage data flow and program state during execution."
      }
    ],

    "basic_terms": {
      "datatype": "Defines what type of value can be stored.",
      "variable_name": "The name used to access stored value.",
      "value": "Actual information stored in variable.",
      "assignment_operator": "= stores value inside variable.",

      "example": "int age = 20;",

      "breakdown": [
        "int → datatype",
        "age → variable name",
        "= → assignment operator",
        "20 → stored value",
        "; → statement ending"
      ]
    },

    "syntax": {
      "code": "datatype variableName = value;",
      "explanation": "Variables are created using datatype, variable name, assignment operator, and value."
    },

    "datatype_examples": [

      {
        "datatype": "int",
        "purpose": "Stores whole numbers.",

        "examples": [
          {
            "type": "basic",
            "code": "int age = 20;",
            "output": "age stores 20",

            "step_by_step": [
              "int means whole number datatype",
              "age is variable name",
              "= stores value",
              "20 is saved inside age"
            ],

            "real_life": "Used to store a person's age."
          },

          {
            "type": "student",
            "code": "int marks = 95;",
            "output": "marks stores 95",

            "step_by_step": [
              "marks variable is created",
              "95 is stored as exam marks"
            ],

            "real_life": "Used in school marks system."
          },

          {
            "type": "gaming",
            "code": "int score = 100;",
            "output": "score stores 100",

            "step_by_step": [
              "score variable stores player score",
              "100 becomes current score"
            ],

            "real_life": "Used in games to track points."
          },

          {
            "type": "shopping",
            "code": "int quantity = 5;",
            "output": "quantity stores 5",

            "step_by_step": [
              "quantity variable is created",
              "5 products are stored as quantity"
            ],

            "real_life": "Used in shopping carts."
          },

          {
            "type": "sports",
            "code": "int runs = 87;",
            "output": "runs stores 87",

            "step_by_step": [
              "runs variable stores cricket score",
              "87 becomes current runs"
            ],

            "real_life": "Used in sports scoreboards."
          }
        ]
      },

      {
        "datatype": "String",
        "purpose": "Stores text values.",

        "examples": [
          {
            "type": "basic",
            "code": "String name = \"John\";",
            "output": "name stores John",

            "step_by_step": [
              "String means text datatype",
              "name is variable name",
              "John is stored inside double quotes"
            ],

            "real_life": "Stores person name."
          },

          {
            "type": "social_media",
            "code": "String username = \"brainzo_user\";",
            "output": "username stores brainzo_user",

            "step_by_step": [
              "username variable is created",
              "text value is stored"
            ],

            "real_life": "Used in Instagram or gaming accounts."
          },

          {
            "type": "education",
            "code": "String college = \"ABC College\";",
            "output": "college stores ABC College",

            "step_by_step": [
              "college variable stores institution name",
              "text is stored inside quotes"
            ],

            "real_life": "Used in student databases."
          },

          {
            "type": "technology",
            "code": "String language = \"Java\";",
            "output": "language stores Java",

            "step_by_step": [
              "language variable stores programming language name"
            ],

            "real_life": "Used in coding apps."
          },

          {
            "type": "app",
            "code": "String appName = \"Brainzo\";",
            "output": "appName stores Brainzo",

            "step_by_step": [
              "appName variable stores app title"
            ],

            "real_life": "Used in applications and software."
          }
        ]
      },

      {
