    "wrong_vs_correct": [
      {
        "wrong": "int age = \"20\";",
        "correct": "int age = 20;",
        "why_wrong": "int cannot store text values. Numbers for int should not be inside quotes."
      },
      {
        "wrong": "String name = 'John';",
        "correct": "String name = \"John\";",
        "why_wrong": "String values must use double quotes."
      },
      {
        "wrong": "char grade = \"A\";",
        "correct": "char grade = 'A';",
        "why_wrong": "char stores only one character using single quotes."
      },
      {
        "wrong": "boolean isStudent = \"true\";",
        "correct": "boolean isStudent = true;",
        "why_wrong": "boolean stores true or false without quotes."
      },
      {
        "wrong": "double price = \"99.99\";",
        "correct": "double price = 99.99;",
        "why_wrong": "double stores decimal numbers without quotes."
      }
    ],

