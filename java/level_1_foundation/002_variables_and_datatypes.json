{
  "id": "java_foundation_002",
  "title": "Variables and Datatypes",
  "difficulty": "Beginner",
  "estimatedMinutes": 35,
  "content": {
    "topic_intro": "Variables are used to store data in Java programs. They help a program remember information like names, ages, scores, prices, marks, login status, and many other values.",

    "why_learn_this": "Without variables, programs cannot store or use information. Every real app, game, website, banking system, and learning platform uses variables to manage data.",

    "explanations": [
      {
        "type": "simple",
        "text": "A variable is a container used to store data."
      },
      {
        "type": "real_life",
        "text": "A variable is like a labeled box. The label is the variable name, and the item inside the box is the value."
      },
      {
        "type": "student_friendly",
        "text": "Variables help programs remember things like student names, marks, grades, and pass status."
      },
      {
        "type": "technical",
        "text": "A variable reserves memory space to store a value of a specific datatype."
      },
      {
        "type": "deep",
        "text": "A variable combines a datatype, a variable name, and a value so a Java program can store, update, and use information during execution."
      }
    ],

    "basic_terms": {
      "datatype": "Defines what type of value can be stored.",
      "variable_name": "The name used to access the stored value.",
      "value": "The actual data stored inside the variable.",
      "assignment_operator": "= is used to store a value inside a variable.",
      "semicolon": "; is used to end most Java statements.",

      "example": "int age = 20;",

      "breakdown": [
        "int → datatype",
        "age → variable name",
        "= → assignment operator",
        "20 → stored value",
        "; → statement ending"
      ]
    },

    "syntax": {
      "code": "datatype variableName = value;",
      "explanation": "Variables are created using a datatype, variable name, assignment operator, value, and semicolon."
    },

    "datatype_examples": [
