    },

    "revision_summary": [
      "Variables store data.",
      "Datatypes define what kind of value can be stored.",
      "int stores whole numbers.",
      "String stores text.",
      "double stores decimals.",
      "char stores single characters.",
      "boolean stores true or false."
    ]
  }
