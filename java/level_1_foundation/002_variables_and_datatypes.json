        "answer": "int"
      },

      {
        "question": "Which datatype stores text?",
        "answer": "String"
      },

      {
        "question": "Which datatype stores decimal numbers?",
        "answer": "double"
      },

      {
        "question": "Which datatype stores one character?",
        "answer": "char"
      },

      {
        "question": "Which datatype stores true or false?",
        "answer": "boolean"
      }
    ],

    "mini_project": {
