{
  "id": "java_foundation_005",
  "title": "User Input in Java",
  "difficulty": "Beginner",
  "estimatedMinutes": 50,

  "content": {
    "topic_intro": {
      "text": "User input allows Java programs to take information from users while the program is running. Apps use user input for login forms, chat systems, search bars, registration forms, passwords, and many other features."
    },

    "why_learn_this": [
      "User input makes programs interactive",
      "Apps need input for names, passwords, and search",
      "Games use user input for controls and actions",
      "Forms and registration systems require input",
      "Almost every real-world application uses user input"
    ],

    "explanations": [
      {
        "type": "simple",
        "text": "User input means taking data from users."
      },

      {
        "type": "real_life",
        "text": "Whenever an app asks for your name, age, password, or message, it is taking user input."
      },

      {
        "type": "student_friendly",
        "text": "Input makes programs interactive instead of fixed."
      },

      {
        "type": "technical",
        "text": "Java uses the Scanner class to read data from keyboard input."
      },

      {
        "type": "deep",
        "text": "User input systems allow software applications to collect and process data dynamically during execution."
      }
    ],

    "basic_terms": [
      {
        "term": "Scanner",
        "meaning": "Java class used for taking input."
      },

      {
        "term": "System.in",
        "meaning": "Represents keyboard input stream."
      },

      {
        "term": "nextInt()",
        "meaning": "Reads integer input."
      },

      {
        "term": "nextLine()",
        "meaning": "Reads full text input."
      },

      {
        "term": "Input Stream",
        "meaning": "Flow of data from keyboard into program."
      }
    ],

    "setup": {
      "title": "Import Scanner",

      "code": "import java.util.Scanner;",

      "explanation": "Scanner class must be imported before use."
    },

    "scanner_setup_explanations": [
      {
        "type": "simple",
        "text": "Scanner helps programs take keyboard input."
      },

      {
        "type": "student_friendly",
        "text": "Scanner listens to what the user types."
      },

      {
        "type": "real_life",
        "text": "Scanner works like a form collecting information from users."
      },

      {
        "type": "technical",
        "text": "Scanner reads data from System.in input stream."
      },

      {
        "type": "deep",
        "text": "Scanner converts keyboard data into usable Java values."
      }
    ],

    "basic_input_program": {
      "title": "Simple User Input Program",

      "code": "import java.util.Scanner;\n\npublic class Main {\n    public static void main(String[] args) {\n\n        Scanner sc = new Scanner(System.in);\n\n        System.out.println(\"Enter your name:\");\n\n        String name = sc.nextLine();\n\n        System.out.println(\"Hello \" + name);\n    }\n}",

      "step_by_step": [
        "Scanner object is created",
        "Program asks for name",
        "User types name",
        "nextLine() stores text input",
        "Program prints greeting"
      ],

      "output_example": [
        "Enter your name:",
        "John",
        "Hello John"
      ]
    },

