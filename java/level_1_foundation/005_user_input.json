    "important_note": {
      "title": "Difference Between next() and nextLine()",

      "next()": "Reads only one word.",

      "nextLine()": "Reads full sentence including spaces.",

      "explanations": [
        {
          "type": "simple",
          "text": "next() reads one word while nextLine() reads full sentence."
        },

        {
          "type": "student_friendly",
          "text": "nextLine() is better when spaces are needed."
        },

        {
          "type": "real_life",
          "text": "Chat apps use nextLine() for full messages."
        },

        {
          "type": "technical",
          "text": "next() stops reading at spaces while nextLine() reads entire line."
        },

        {
          "type": "deep",
          "text": "Choosing correct Scanner method is important for accurate input handling."
        }
      ],

      "example": {
        "code": "String name = sc.next();",

        "output": "John",

        "code2": "String fullName = sc.nextLine();",

        "output2": "John Doe"
      }
    },

    "wrong_vs_correct": [
      {
        "wrong": "Scanner sc = Scanner(System.in);",
        "correct": "Scanner sc = new Scanner(System.in);",
        "why_wrong": "new keyword is required."
      },

      {
        "wrong": "int age = sc.nextLine();",
        "correct": "int age = sc.nextInt();",
        "why_wrong": "nextLine() returns String."
      },

      {
        "wrong": "String name = sc.nextInt();",
        "correct": "String name = sc.nextLine();",
        "why_wrong": "nextInt() reads integer only."
      },

      {
        "wrong": "double price = sc.nextInt();",
        "correct": "double price = sc.nextDouble();",
        "why_wrong": "nextDouble() reads decimal values."
      },

      {
        "wrong": "Scanner sc;",
        "correct": "Scanner sc = new Scanner(System.in);",
        "why_wrong": "Scanner object must be created."
      }
    ],

