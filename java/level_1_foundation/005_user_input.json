    "wrong_vs_correct": [
      {
        "wrong": "Scanner sc = Scanner(System.in);",
        "correct": "Scanner sc = new Scanner(System.in);",
        "why_wrong": "new keyword is required to create object."
      },

      {
        "wrong": "int age = sc.nextLine();",
        "correct": "int age = sc.nextInt();",
        "why_wrong": "nextLine() returns String, not int."
      },

      {
        "wrong": "String name = sc.nextInt();",
        "correct": "String name = sc.nextLine();",
        "why_wrong": "nextInt() reads integer only."
      }
