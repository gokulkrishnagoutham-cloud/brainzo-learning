{
  "id": "java_foundation_005",
  "title": "User Input in Java",
  "difficulty": "Beginner",
  "estimatedMinutes": 40,

  "content": {
    "topic_intro": "User input allows programs to take data from users during execution.",

    "why_learn_this": "Without user input, programs cannot interact with users. Real apps need names, passwords, messages, search queries, and many other inputs.",

    "explanations": [
      {
        "type": "simple",
        "text": "User input means taking data from the user."
      },

      {
        "type": "real_life",
        "text": "Whenever an app asks for your name, password, or age, it is taking user input."
      },

      {
        "type": "student_friendly",
        "text": "Input makes programs interactive instead of fixed."
      },

      {
        "type": "technical",
        "text": "Java uses the Scanner class to read data from keyboard input."
      },

      {
        "type": "deep",
        "text": "User input systems allow dynamic runtime interaction between users and software applications by capturing external data streams."
      }
    ],

    "basic_terms": {
      "Scanner": "Java class used for taking input.",
      "System.in": "Represents keyboard input stream.",
      "nextInt()": "Reads integer input.",
      "nextLine()": "Reads full text input.",

      "example": "Scanner sc = new Scanner(System.in);",

      "breakdown": [
        "Scanner creates input object",
        "sc is object name",
        "new creates object",
        "System.in connects keyboard input"
      ]
    },

    "setup": {
      "title": "Import Scanner",

      "code": "import java.util.Scanner;",

      "explanation": "Scanner class must be imported before use."
    },

    "basic_input_program": {
      "title": "Simple User Input Program",

      "code": "import java.util.Scanner;\n\npublic class Main {\n    public static void main(String[] args) {\n\n        Scanner sc = new Scanner(System.in);\n\n        System.out.println(\"Enter your name:\");\n\n        String name = sc.nextLine();\n\n        System.out.println(\"Hello \" + name);\n    }\n}",

      "step_by_step": [
        "Scanner object is created",
        "Program asks for name",
        "User types name",
        "nextLine() stores text input",
        "Program prints greeting"
      ],

      "output_example": [
        "Enter your name:",
        "John",
        "Hello John"
      ]
    },

