    "important_note": {
      "title": "Difference Between next() and nextLine()",

      "next()": "Reads only one word.",
      "nextLine()": "Reads full sentence including spaces.",

      "example": {
        "code": "String name = sc.next();",
        "output": "John",

        "code2": "String fullName = sc.nextLine();",
        "output2": "John Doe"
      }
