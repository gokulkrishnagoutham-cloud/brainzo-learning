{
  "id": "java_foundation_003",
  "title": "Operators in Java",
  "difficulty": "Beginner",
  "estimatedMinutes": 45,

  "content": {
    "topic_intro": {
      "text": "Operators are symbols used to perform actions on values and variables in Java. They help programs calculate numbers, compare values, update data, and make decisions."
    },

    "why_learn_this": [
      "Operators are used in every Java program",
      "They help perform calculations",
      "They help compare values and make decisions",
      "Operators are important in games, banking apps, websites, and mobile apps",
      "Understanding operators is required for conditions, loops, and advanced Java concepts"
    ],

    "basic_terms": [
      {
        "term": "Operator",
        "meaning": "A symbol that performs an operation."
      },
      {
        "term": "Operand",
        "meaning": "The value or variable used with an operator."
      },
      {
        "term": "Expression",
        "meaning": "A combination of values, variables, and operators."
      },
      {
        "term": "Result",
        "meaning": "The final answer after an operation."
      },
      {
        "term": "Assignment",
        "meaning": "Storing a value inside a variable."
      }
    ],

    "operator_types": [

      {
        "name": "Arithmetic Operators",
        "purpose": "Used for mathematical calculations.",

        "explanations": [
          {
            "type": "simple",
            "text": "Arithmetic operators are used for mathematical calculations."
          },
          {
            "type": "student_friendly",
            "text": "They help add, subtract, multiply, divide, and find remainder."
          },
          {
            "type": "real_life",
            "text": "Arithmetic operators work like calculator buttons."
          },
          {
            "type": "technical",
            "text": "Arithmetic operators perform mathematical operations on numeric operands."
          },
          {
            "type": "deep",
            "text": "Arithmetic operators are essential in billing systems, banking apps, games, analytics, and scientific calculations."
          }
        ],

        "examples": [
          {
            "code": "int sum = 10 + 5;",
            "output": "15",

            "step_by_step": [
              "10 and 5 are numbers",
              "+ adds both values",
              "15 is stored in sum"
            ],

            "real_life": "Adding marks of two subjects."
          },

          {
            "code": "int difference = 20 - 8;",
            "output": "12",

            "step_by_step": [
              "20 is the starting value",
              "- subtracts 8",
              "12 becomes final answer"
            ],

            "real_life": "Finding remaining money after shopping."
          },

          {
            "code": "int product = 4 * 5;",
            "output": "20",

            "step_by_step": [
              "4 and 5 are multiplied",
              "* means multiplication",
              "20 is stored in product"
            ],

            "real_life": "Calculating total price of multiple products."
          },

          {
            "code": "int result = 20 / 4;",
            "output": "5",

            "step_by_step": [
              "20 is divided by 4",
              "/ means division",
              "5 becomes result"
            ],

            "real_life": "Sharing chocolates equally among friends."
          },

          {
            "code": "int remainder = 10 % 3;",
            "output": "1",

            "step_by_step": [
              "10 divided by 3 leaves remainder 1",
              "% gives only the remainder",
              "1 is stored in remainder"
            ],

            "real_life": "Checking whether number is even or odd."
          }
        ]
      },

      {
        "name": "Assignment Operators",
        "purpose": "Used to assign or update values.",

        "explanations": [
          {
            "type": "simple",
            "text": "Assignment operators store values inside variables."
          },
          {
            "type": "student_friendly",
            "text": "They help update existing values quickly."
          },
          {
            "type": "real_life",
            "text": "Assignment operators are like saving updated information in an app."
          },
          {
            "type": "technical",
            "text": "Assignment operators assign or modify variable values."
          },
          {
            "type": "deep",
            "text": "Assignment operators simplify updating variables during program execution."
          }
        ],

        "examples": [
          {
            "code": "int age = 20;",
            "output": "age stores 20",

            "step_by_step": [
              "int creates variable",
              "age becomes variable name",
              "= stores 20 inside age"
            ],

            "real_life": "Saving age in user profile."
          },

          {
            "code": "score += 10;",
            "output": "score increases by 10",

            "step_by_step": [
              "score already contains value",
              "+= adds 10",
              "new value replaces old value"
            ],

            "real_life": "Adding bonus points in game."
          },

          {
            "code": "stock -= 2;",
            "output": "stock decreases by 2",

            "step_by_step": [
              "-= subtracts 2 from stock",
              "updated value is saved again"
            ],

            "real_life": "Reducing product quantity after purchase."
          },

          {
            "code": "marks *= 2;",
            "output": "marks become double",

            "step_by_step": [
              "*= multiplies marks by 2",
              "new value replaces old value"
            ],

            "real_life": "Applying double bonus marks."
          },

          {
            "code": "price /= 2;",
            "output": "price becomes half",

            "step_by_step": [
              "/= divides current value by 2",
              "updated value gets stored again"
            ],

            "real_life": "Applying 50% discount."
          }
        ]
      },

      {
        "name": "Comparison Operators",
        "purpose": "Used to compare values. Result becomes true or false.",

        "explanations": [
          {
            "type": "simple",
            "text": "Comparison operators compare two values."
          },
          {
            "type": "student_friendly",
            "text": "They help programs check conditions."
          },
          {
            "type": "real_life",
            "text": "Comparison operators are used like checking pass/fail conditions."
          },
          {
            "type": "technical",
            "text": "Comparison operators return boolean values."
          },
          {
            "type": "deep",
            "text": "Comparison operators are heavily used in conditions, loops, authentication systems, and validations."
          }
        ],

        "examples": [
          {
            "code": "10 == 10",
            "output": "true",

            "step_by_step": [
              "== checks equality",
              "Both values are equal",
              "Result becomes true"
            ],

            "real_life": "Checking password match."
          },

          {
            "code": "10 != 5",
            "output": "true",

            "step_by_step": [
              "!= checks inequality",
              "10 and 5 are different",
              "Result becomes true"
            ],

            "real_life": "Checking usernames are different."
          },

          {
            "code": "20 > 10",
            "output": "true",

            "step_by_step": [
              "> checks greater value",
              "20 is larger than 10",
              "Result becomes true"
            ],

            "real_life": "Checking eligibility score."
          },

          {
            "code": "5 < 8",
            "output": "true",

            "step_by_step": [
              "< checks smaller value",
              "5 is smaller than 8",
              "Result becomes true"
            ],

            "real_life": "Checking low stock."
          },

          {
            "code": "10 >= 10",
            "output": "true",

            "step_by_step": [
              ">= means greater than or equal",
              "10 equals 10",
              "Result becomes true"
            ],

            "real_life": "Checking minimum age requirement."
          }
        ]
      },

      {
        "name": "Logical Operators",
        "purpose": "Used to combine multiple conditions.",

        "explanations": [
          {
            "type": "simple",
            "text": "Logical operators combine conditions."
          },
          {
            "type": "student_friendly",
            "text": "They help programs make smart decisions."
          },
          {
            "type": "real_life",
            "text": "Logical operators work like checking multiple rules together."
          },
          {
            "type": "technical",
            "text": "Logical operators operate on boolean expressions."
          },
          {
            "type": "deep",
            "text": "Logical operators are essential in authentication systems, eligibility systems, and decision-making programs."
          }
        ],

        "examples": [
          {
            "code": "age > 18 && marks > 50",
            "output": "true only if both conditions are true",

            "step_by_step": [
              "&& means AND",
              "Both conditions must be true",
              "Otherwise result becomes false"
            ],

            "real_life": "Checking college eligibility."
          },

          {
            "code": "isAdmin || isTeacher",
            "output": "true if one condition is true",

            "step_by_step": [
              "|| means OR",
              "At least one condition should be true"
            ],

            "real_life": "Checking dashboard access."
          },

          {
            "code": "!isLoggedIn",
            "output": "opposite boolean value",

            "step_by_step": [
              "! reverses boolean value",
              "true becomes false",
              "false becomes true"
            ],

            "real_life": "Checking user is not logged in."
          },

          {
            "code": "health > 0 && ammo > 0",
            "output": "player can fight",

            "step_by_step": [
              "Player needs health",
              "Player also needs ammo",
              "Both conditions are required"
            ],

            "real_life": "Gaming systems."
          },

          {
            "code": "isPremium || hasFreeTrial",
            "output": "user can access feature",

            "step_by_step": [
              "Premium users can access",
              "Trial users can also access",
              "One condition is enough"
            ],

            "real_life": "Subscription applications."
          }
        ]
      }
    ],

    "wrong_vs_correct": [
      {
        "wrong": "if(age = 18)",
        "correct": "if(age == 18)",
        "why_wrong": "= assigns value while == compares values."
      },

      {
        "wrong": "int result = 10 / 0;",
        "correct": "int result = 10 / 2;",
        "why_wrong": "Division by zero causes error."
      },

      {
        "wrong": "score =+ 5;",
        "correct": "score += 5;",
        "why_wrong": "+= means add and assign."
      },

      {
        "wrong": "if(marks => 50)",
        "correct": "if(marks >= 50)",
        "why_wrong": ">= is the correct operator."
      },

      {
        "wrong": "boolean result = 10 >;",
        "correct": "boolean result = 10 > 5;",
        "why_wrong": "Comparison operators need two values."
      }
    ],

    "common_mistakes": [
      "Using = instead of ==",
      "Confusing && and ||",
      "Forgetting comparison operators return true or false",
      "Using % without understanding remainder",
      "Dividing by zero"
    ],

    "practice": [
      "Create two int variables and add them.",
      "Subtract two numbers using operators.",
      "Multiply and divide two numbers.",
      "Check if age is greater than 18.",
      "Use logical operators with conditions."
    ],

    "quiz": [
      {
        "question": "Which operator is used for addition?",
        "answer": "+"
      },

      {
        "question": "Which operator checks equality?",
        "answer": "=="
      },

      {
        "question": "Which operator gives remainder?",
        "answer": "%"
      },

      {
        "question": "Which operator means AND?",
        "answer": "&&"
      },

      {
        "question": "Which operator means OR?",
        "answer": "||"
      }
    ],

    "mini_project": {
      "title": "Simple Calculator",
      "task": "Create a calculator program that adds, subtracts, multiplies, divides, and finds remainder of two numbers."
    },

    "revision_summary": [
      "Operators perform actions on values and variables.",
      "Arithmetic operators perform calculations.",
      "Assignment operators assign or update values.",
      "Comparison operators return true or false.",
      "Logical operators combine multiple conditions."
    ]
  }
}
