{
  "id": "java_foundation_007",
  "title": "Code Debugging in Java",
  "difficulty": "Beginner",
  "estimatedMinutes": 55,

  "content": {
    "topic_intro": {
      "text": "Debugging means finding and fixing problems in Java programs. Every programmer makes mistakes, and debugging helps identify errors and make programs work correctly."
    },

    "why_learn_this": [
      "Every programmer encounters errors while coding",
      "Debugging helps programs work correctly",
      "Apps crash without proper debugging",
      "Companies spend huge time fixing bugs",
      "Good debugging skills make developers faster and smarter"
    ],

    "explanations": [
      {
        "type": "simple",
        "text": "Debugging means fixing errors in code."
      },

      {
        "type": "real_life",
        "text": "Debugging is like repairing a broken machine by finding which part causes the problem."
      },

      {
        "type": "student_friendly",
        "text": "When your code does not work, debugging helps understand why."
      },

      {
        "type": "technical",
        "text": "Debugging is the process of locating, analyzing, and resolving software errors."
      },

      {
        "type": "deep",
        "text": "Debugging involves tracing execution flow, identifying failures, and correcting syntax, runtime, or logical issues."
      }
    ],

    "basic_terms": [
      {
        "term": "Bug",
        "meaning": "An error or problem in code."
      },

      {
        "term": "Debugging",
        "meaning": "The process of fixing bugs."
      },

      {
        "term": "Syntax Error",
        "meaning": "Error caused by incorrect Java syntax."
      },

      {
        "term": "Runtime Error",
        "meaning": "Error occurring while program executes."
      },

      {
        "term": "Logical Error",
        "meaning": "Program runs but produces wrong output."
      }
    ],

    "error_types": [

      {
        "name": "Syntax Errors",

        "purpose": "Errors caused by incorrect Java syntax.",

        "explanations": [
          {
            "type": "simple",
            "text": "Syntax errors happen when Java rules are broken."
          },

          {
            "type": "student_friendly",
            "text": "The program cannot start because code format is wrong."
          },

          {
            "type": "real_life",
            "text": "Syntax errors are like spelling mistakes in language."
          },

          {
            "type": "technical",
            "text": "Compiler detects syntax errors before execution."
          },

          {
            "type": "deep",
            "text": "Syntax errors prevent successful compilation because Java grammar rules are violated."
          }
        ],

        "examples": [
          {
            "wrong_code": "int age = ;",

            "correct_code": "int age = 20;",

            "why_wrong": "Value is missing after assignment operator.",

            "step_by_step": [
              "Java expects a value",
              "No value is provided",
              "Compiler detects invalid syntax",
              "Compilation fails",
              "Program cannot run"
            ],

            "real_life": "Like leaving answer blank in form."
          },

          {
            "wrong_code": "System.out.println(\"Hello\")",

            "correct_code": "System.out.println(\"Hello\");",

            "why_wrong": "Semicolon is missing.",

            "step_by_step": [
              "Java statements require semicolon",
              "Compiler checks statement ending",
              "Semicolon is missing",
              "Syntax error appears",
              "Program stops compiling"
            ],

            "real_life": "Like missing punctuation in sentence."
          },

          {
            "wrong_code": "String name = 'John';",

            "correct_code": "String name = \"John\";",

            "why_wrong": "Strings use double quotes.",

            "step_by_step": [
              "Java reads single quotes",
              "Single quotes are for char",
              "String requires double quotes",
              "Compiler detects mismatch",
              "Compilation fails"
            ],

            "real_life": "Using wrong container for object."
          },

          {
            "wrong_code": "if(age = 18)",

            "correct_code": "if(age == 18)",

            "why_wrong": "= assigns value while == compares values.",

            "step_by_step": [
              "if expects comparison",
              "= changes variable value",
              "Condition becomes invalid",
              "Compiler shows error",
              "Program cannot continue"
            ],

            "real_life": "Confusing assignment with checking."
          },

          {
            "wrong_code": "public clas Main",

            "correct_code": "public class Main",

            "why_wrong": "class keyword spelling is incorrect.",

            "step_by_step": [
              "Java checks keywords",
              "clas is invalid keyword",
              "Compiler cannot recognize it",
              "Syntax error appears",
              "Compilation stops"
            ],

            "real_life": "Typing wrong spelling in exam."
          }
        ]
      },

      {
        "name": "Runtime Errors",

        "purpose": "Errors occurring during execution.",

        "explanations": [
          {
            "type": "simple",
            "text": "Runtime errors happen while program is running."
          },

          {
            "type": "student_friendly",
            "text": "The program starts but crashes during execution."
          },

          {
            "type": "real_life",
            "text": "Apps crashing suddenly is often caused by runtime errors."
          },

          {
            "type": "technical",
            "text": "Runtime errors occur after successful compilation."
          },

          {
            "type": "deep",
            "text": "Runtime failures happen due to invalid operations during execution flow."
          }
        ],

        "examples": [
          {
            "wrong_code": "int result = 10 / 0;",

            "correct_code": "int result = 10 / 2;",

            "why_wrong": "Division by zero is impossible.",

            "step_by_step": [
              "Program compiles correctly",
              "Execution begins",
              "Division by zero occurs",
              "ArithmeticException happens",
              "Program crashes"
            ],

            "real_life": "Impossible mathematical operation."
          },

          {
            "wrong_code": "String name = null;\nSystem.out.println(name.length());",

            "correct_code": "String name = \"John\";\nSystem.out.println(name.length());",

            "why_wrong": "null has no value to access.",

            "step_by_step": [
              "name stores null",
              "length() tries accessing value",
              "No object exists",
              "NullPointerException occurs",
              "Program crashes"
            ],

            "real_life": "Trying to open empty box."
          },

          {
            "wrong_code": "int[] arr = new int[3];\nSystem.out.println(arr[5]);",

            "correct_code": "System.out.println(arr[2]);",

            "why_wrong": "Array index exceeds size.",

            "step_by_step": [
              "Array size becomes 3",
              "Valid indexes are 0,1,2",
              "Index 5 does not exist",
              "ArrayIndexOutOfBoundsException occurs",
              "Program crashes"
            ],

            "real_life": "Trying to access missing shelf."
          },

          {
            "wrong_code": "Scanner sc = null;\nsc.nextInt();",

            "correct_code": "Scanner sc = new Scanner(System.in);",

            "why_wrong": "Scanner object was never created.",

            "step_by_step": [
              "Scanner stores null",
              "nextInt() is called",
              "No object exists",
              "NullPointerException occurs",
              "Program crashes"
            ],

            "real_life": "Using machine that was never turned on."
          },

          {
            "wrong_code": "String text = \"Java\";\nSystem.out.println(text.charAt(10));",

            "correct_code": "System.out.println(text.charAt(1));",

            "why_wrong": "Character position exceeds String length.",

            "step_by_step": [
              "Java has length 4",
              "Index 10 does not exist",
              "Program checks invalid position",
              "StringIndexOutOfBoundsException occurs",
              "Program crashes"
            ],

            "real_life": "Trying to access missing page in book."
          }
        ]
      },

      {
        "name": "Logical Errors",

        "purpose": "Program runs but gives wrong output.",

        "explanations": [
          {
            "type": "simple",
            "text": "Logical errors produce wrong results."
          },

          {
            "type": "student_friendly",
            "text": "The program works but answers are incorrect."
          },

          {
            "type": "real_life",
            "text": "Wrong calculations in banking apps are logical errors."
          },

          {
            "type": "technical",
            "text": "Logical errors occur due to incorrect program logic."
          },

          {
            "type": "deep",
            "text": "Logical flaws produce unexpected behavior despite successful execution."
          }
        ],

        "examples": [
          {
            "wrong_code": "int total = 10 - 5;",

            "correct_code": "int total = 10 + 5;",

            "why_wrong": "Wrong operator used.",

            "step_by_step": [
              "Program executes successfully",
              "Subtraction happens instead of addition",
              "Wrong result is generated",
              "Logic becomes incorrect",
              "Output becomes wrong"
            ],

            "real_life": "Incorrect billing calculation."
          },

          {
            "wrong_code": "if(age > 18)",

            "correct_code": "if(age >= 18)",

            "why_wrong": "18 should also be included.",

            "step_by_step": [
              "Condition checks greater than 18",
              "Age 18 is ignored",
              "Logic becomes incomplete",
              "Wrong condition is used",
              "Users get wrong result"
            ],

            "real_life": "Wrong eligibility checking."
          },

          {
            "wrong_code": "double average = total / count;",

            "correct_code": "double average = (double) total / count;",

            "why_wrong": "Integer division removes decimal values.",

            "step_by_step": [
              "Both values are int",
              "Integer division occurs",
              "Decimal values are removed",
              "Wrong average appears",
              "Output becomes inaccurate"
            ],

            "real_life": "Incorrect student average calculation."
          },

          {
            "wrong_code": "if(password == \"admin\")",

            "correct_code": "if(password.equals(\"admin\"))",

            "why_wrong": "== compares references instead of content.",

            "step_by_step": [
              "== compares memory references",
              "String content is ignored",
              "Condition becomes unreliable",
              "Wrong login result appears",
              "Program logic fails"
            ],

            "real_life": "Login system bug."
          },

          {
            "wrong_code": "for(int i = 1; i <= 5; i--)",

            "correct_code": "for(int i = 1; i <= 5; i++)",

            "why_wrong": "Loop moves in wrong direction.",

            "step_by_step": [
              "Loop starts at 1",
              "i decreases instead of increasing",
              "Condition never becomes false",
              "Infinite loop occurs",
              "Program hangs"
            ],

            "real_life": "Frozen applications."
          }
        ]
      }
    ],

    "debugging_methods": [

      {
        "method": "Reading Error Messages",

        "explanations": [
