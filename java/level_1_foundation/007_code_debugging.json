          },

          {
            "type": "technical",
            "text": "Exceptions provide stack trace information."
          },

          {
            "type": "deep",
            "text": "Understanding exceptions speeds up debugging significantly."
          }
        ],

        "example": "Exception in thread \"main\" java.lang.ArithmeticException: / by zero"
      },

      {
        "method": "Using print statements",

        "explanations": [
          {
            "type": "simple",
            "text": "Print statements help track values."
          },

          {
            "type": "student_friendly",
            "text": "Print variables to understand execution flow."
          },

          {
            "type": "real_life",
            "text": "Developers use logs to identify issues."
          },

          {
            "type": "technical",
            "text": "Console output helps inspect runtime state."
          },

          {
            "type": "deep",
            "text": "Tracing variable changes helps isolate program failures."
          }
        ],

        "example": "System.out.println(age);"
      }
    ],

    "real_world_debugging": [
