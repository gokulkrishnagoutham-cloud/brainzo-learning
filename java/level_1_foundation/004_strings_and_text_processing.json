{
  "id": "java_foundation_004",
  "title": "Strings and Text Processing",
  "difficulty": "Beginner",
  "estimatedMinutes": 45,

  "content": {
    "topic_intro": {
      "text": "Strings are used to store and work with text in Java. Names, messages, emails, passwords, search text, chat messages, and notifications all use Strings."
    },

    "why_learn_this": [
      "Strings are used in almost every application",
      "Apps use Strings for usernames, messages, and search",
      "Strings help programs process and display text",
      "Text processing is important in websites and mobile apps",
      "Understanding Strings is important for backend and frontend development"
    ],

    "explanations": [
      {
        "type": "simple",
        "text": "A String stores text in Java."
      },

      {
        "type": "real_life",
        "text": "A String is like a sentence written on paper and stored inside a variable."
      },

      {
        "type": "student_friendly",
        "text": "Whenever you type names, passwords, messages, or comments in apps, Strings are being used."
      },

      {
        "type": "technical",
        "text": "String is a Java class used to store sequences of characters."
      },

      {
        "type": "deep",
        "text": "Strings manage textual data and provide methods for searching, formatting, comparison, joining, and manipulation."
      }
    ],

    "basic_terms": [
      {
        "term": "String",
        "meaning": "Datatype used to store text."
      },

      {
        "term": "Characters",
        "meaning": "Letters, numbers, symbols, and spaces inside text."
      },

      {
        "term": "Double Quotes",
        "meaning": "Strings must always use double quotes."
      },

      {
        "term": "Concatenation",
        "meaning": "Joining multiple Strings together."
      },

      {
        "term": "String Method",
        "meaning": "Built-in function used to perform operations on Strings."
      }
    ],

    "syntax": {
      "title": "Creating Strings",

      "code": "String name = \"John\";\nString city = \"Chennai\";\nString appName = \"Brainzo\";",

      "explanation": "Strings store text values using double quotes."
    },

    "string_examples": [

      {
        "type": "basic",

        "code": "String name = \"John\";",

        "output": "name stores John",

        "step_by_step": [
          "String datatype is used",
          "name variable is created",
          "John is stored as text",
          "Double quotes are required",
          "The value is saved inside variable"
        ],

        "real_life": "Used for storing usernames."
      },

      {
        "type": "social_media",

        "code": "String username = \"brainzo_user\";",

        "output": "username stores brainzo_user",

        "step_by_step": [
          "username variable is created",
          "Text is stored as account name",
          "The value is inside double quotes",
          "Java stores it as String",
          "The variable can be reused later"
        ],

        "real_life": "Used in Instagram or gaming profiles."
      },

      {
        "type": "chat_app",

        "code": "String message = \"Hello World\";",

        "output": "message stores Hello World",

        "step_by_step": [
          "message variable is created",
          "Text message is stored",
          "Spaces are allowed in Strings",
          "Text is saved inside quotes",
          "The value can be printed later"
        ],

        "real_life": "Used in chat applications."
      },

      {
        "type": "education",

        "code": "String college = \"ABC College\";",

        "output": "college stores ABC College",

        "step_by_step": [
          "college variable is created",
          "Institution name is stored",
          "Text uses double quotes",
          "String datatype handles text",
          "The value can be displayed later"
        ],

        "real_life": "Used in student systems."
      },

      {
        "type": "application",

        "code": "String appName = \"Brainzo\";",

        "output": "appName stores Brainzo",

        "step_by_step": [
          "appName variable is created",
          "Application title is stored",
          "Text is saved as String",
          "Double quotes define text",
          "The variable can be reused anywhere"
        ],

        "real_life": "Used in software applications."
      }
    ],

    "string_methods": [

      {
        "method": "length()",

        "purpose": "Finds total number of characters.",

        "explanations": [
          {
            "type": "simple",
            "text": "length() counts characters in String."
          },

          {
            "type": "student_friendly",
            "text": "It tells how many letters are inside text."
          },

          {
            "type": "real_life",
            "text": "Apps use length() to validate passwords."
          },

          {
            "type": "technical",
            "text": "length() returns total number of characters."
          },

          {
            "type": "deep",
            "text": "length() is commonly used in validation systems and input processing."
          }
        ],

        "example": {
          "code": "String name = \"Brainzo\";\nSystem.out.println(name.length());",

          "output": "7",

          "step_by_step": [
            "name variable stores Brainzo",
            "length() counts all characters",
            "Brainzo has 7 letters",
            "The method returns 7",
            "7 gets printed"
          ]
        }
      },

      {
        "method": "toUpperCase()",

        "purpose": "Converts text to uppercase.",

        "explanations": [
          {
            "type": "simple",
            "text": "toUpperCase() converts text into capital letters."
          },

          {
            "type": "student_friendly",
            "text": "It changes small letters into big letters."
          },

          {
            "type": "real_life",
            "text": "Apps use uppercase text in headings and titles."
          },

          {
            "type": "technical",
            "text": "toUpperCase() converts lowercase characters into uppercase."
          },

          {
            "type": "deep",
            "text": "Uppercase conversion helps standardize text formatting."
          }
        ],

        "example": {
          "code": "String city = \"chennai\";\nSystem.out.println(city.toUpperCase());",

          "output": "CHENNAI",

          "step_by_step": [
            "city stores chennai",
            "toUpperCase() converts letters",
            "All characters become uppercase",
            "The converted text is returned",
            "CHENNAI gets printed"
          ]
        }
      },

      {
        "method": "toLowerCase()",

        "purpose": "Converts text to lowercase.",

        "explanations": [
          {
            "type": "simple",
            "text": "toLowerCase() converts text into small letters."
          },

          {
            "type": "student_friendly",
            "text": "It changes capital letters into lowercase."
          },

          {
            "type": "real_life",
            "text": "Search systems often convert text into lowercase."
          },

          {
            "type": "technical",
            "text": "toLowerCase() converts uppercase characters into lowercase."
          },

          {
            "type": "deep",
            "text": "Lowercase conversion helps normalize text processing."
          }
        ],

        "example": {
          "code": "String language = \"JAVA\";\nSystem.out.println(language.toLowerCase());",

          "output": "java",

          "step_by_step": [
            "language stores JAVA",
            "toLowerCase() converts letters",
            "Capital letters become lowercase",
            "The updated text is returned",
            "java gets printed"
          ]
        }
      },

      {
        "method": "contains()",

        "purpose": "Checks whether text exists inside String.",

        "explanations": [
          {
            "type": "simple",
            "text": "contains() checks if text exists."
          },

          {
            "type": "student_friendly",
            "text": "It searches for a word inside another word or sentence."
          },

          {
            "type": "real_life",
            "text": "Search bars use contains() to find matching text."
          },

          {
            "type": "technical",
            "text": "contains() returns true if substring exists."
          },

          {
            "type": "deep",
            "text": "contains() is heavily used in searching and filtering systems."
          }
        ],

        "example": {
          "code": "String text = \"Hello Java\";\nSystem.out.println(text.contains(\"Java\"));",

          "output": "true",

          "step_by_step": [
            "text stores Hello Java",
            "contains() searches for Java",
            "Java exists inside text",
            "The result becomes true",
            "true gets printed"
          ]
        }
      },

      {
        "method": "equals()",

        "purpose": "Compares two Strings.",

        "explanations": [
          {
            "type": "simple",
            "text": "equals() compares two Strings."
          },

          {
            "type": "student_friendly",
            "text": "It checks whether two text values are exactly same."
          },

          {
            "type": "real_life",
            "text": "Login systems use equals() to compare passwords."
          },

          {
            "type": "technical",
            "text": "equals() compares String content."
          },

          {
            "type": "deep",
            "text": "equals() is important in authentication and validation systems."
          }
        ],

        "example": {
          "code": "String a = \"Java\";\nString b = \"Java\";\nSystem.out.println(a.equals(b));",

          "output": "true",

          "step_by_step": [
            "a stores Java",
            "b also stores Java",
            "equals() compares both Strings",
            "Both values are same",
            "true gets printed"
          ]
        }
      }
    ],

    "string_concatenation": {
      "title": "Joining Strings",

      "explanations": [
        {
          "type": "simple",
          "text": "Concatenation joins Strings together."
        },

        {
          "type": "student_friendly",
          "text": "The + operator combines text."
        },

        {
          "type": "real_life",
          "text": "Apps combine first name and last name to create full name."
        },

        {
          "type": "technical",
          "text": "Concatenation creates a new String from multiple Strings."
        },

        {
          "type": "deep",
          "text": "Concatenation is used in dynamic text generation and UI systems."
        }
      ],

      "example": {
        "code": "String firstName = \"John\";\nString lastName = \"Doe\";\nString fullName = firstName + \" \" + lastName;\nSystem.out.println(fullName);",

        "output": "John Doe",

        "step_by_step": [
          "firstName stores John",
          "lastName stores Doe",
          "+ joins both Strings",
          "A space is added in between",
          "John Doe gets printed"
        ]
      }
    },

    "wrong_vs_correct": [
      {
        "wrong": "String name = 'John';",
        "correct": "String name = \"John\";",
        "why_wrong": "Strings always use double quotes."
      },

      {
        "wrong": "String age = 20;",
        "correct": "String age = \"20\";",
        "why_wrong": "String stores text values."
      },

      {
        "wrong": "name.length;",
        "correct": "name.length();",
        "why_wrong": "length() is a method and requires brackets."
      },

      {
        "wrong": "if(name == \"John\")",
        "correct": "if(name.equals(\"John\"))",
        "why_wrong": "equals() should be used for String comparison."
      },

      {
        "wrong": "String city = Chennai;",
        "correct": "String city = \"Chennai\";",
        "why_wrong": "Text values must be inside double quotes."
      }
    ],

    "common_mistakes": [
      "Using single quotes instead of double quotes",
      "Forgetting brackets in methods",
      "Using == instead of equals()",
      "Mixing numbers and Strings incorrectly",
      "Forgetting String is case-sensitive"
    ],

